# ── Telegram ───────────────────────────────────────────────────────────────
# From @BotFather. Treat as a password.
TELEGRAM_BOT_TOKEN=123456:your-bot-token-here
# Random string you invent. Telegram echoes it back in the
# X-Telegram-Bot-Api-Secret-Token header so we can reject spoofed updates.
TELEGRAM_WEBHOOK_SECRET=invent-a-long-random-string

# ── VideoMaking Studio API ───────────────────────────────────────────────────
VMS_API_KEY=vms_live_your_key_here
# Webhook signing secret from the VMS developer panel (HMAC-SHA256 over the body).
VMS_WEBHOOK_SECRET=your-vms-webhook-secret

# ── Local dev runner only (artifacts/api-server) ─────────────────────────────
PORT=5000
# Public HTTPS domain Telegram should call for the local runner
# (e.g. an ngrok/cloudflared tunnel host, no protocol).
WEBHOOK_DOMAIN=

# ── Database (optional locally; required for /history + usage) ────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/bot
